# ============================================================================
# ENVIRONMENT VARIABLES - Copy to .env and fill in your values
# ============================================================================

# =========================
# HUGGING FACE
# =========================
HF_TOKEN=your_hugging_face_token_here
HF_USER=dhruvanmurthy
HF_REPO_ID=qwen3-8b-tool-use-lora

# =========================
# WEIGHTS & BIASES
# =========================
WANDB_API_KEY=your_wandb_api_key_here
WANDB_ENTITY=dhruvanmurthy
WANDB_PROJECT=qwen3-8b-tool-use
WANDB_MODE=online  # or 'offline' for local development

# =========================
# AZURE ML
# =========================
AZURE_SUBSCRIPTION_ID=your_subscription_id_here
AZURE_RESOURCE_GROUP=qwen3-finetuning
AZURE_WORKSPACE_NAME=qwen3-workspace
AZURE_LOCATION=eastus  # or your preferred region
AZURE_COMPUTE_CLUSTER_NAME=gpu-cluster
AZURE_COMPUTE_SKU=Standard_ND_A100_v4  # A100 GPU cluster

# Azure Storage (for datasets)
AZURE_STORAGE_ACCOUNT=your_storage_account_name
AZURE_STORAGE_CONTAINER=datasets
AZURE_STORAGE_KEY=your_storage_key_here

# Azure Key Vault (optional, for production)
AZURE_KEYVAULT_URL=https://your-keyvault.vault.azure.net/

# =========================
# TRAINING CONFIGURATION
# =========================
TRAINING_BATCH_SIZE=16
EVALUATION_BATCH_SIZE=32
LEARNING_RATE=2e-4
NUM_EPOCHS=3
MAX_SEQ_LENGTH=2048
WARMUP_RATIO=0.1
WEIGHT_DECAY=0.01

# Dataset
DATASET_SIZE=40000  # or 'max', 'test' (1k), 'small' (5k)
TRAIN_SPLIT_RATIO=0.8
VAL_SPLIT_RATIO=0.1
TEST_SPLIT_RATIO=0.1

# QLoRA
LORA_R=64
LORA_ALPHA=16
LORA_DROPOUT=0.05
TARGET_MODULES="q_proj,v_proj,k_proj,o_proj,gate_proj,up_proj,down_proj"

# =========================
# COMPUTE & HARDWARE
# =========================
CUDA_VISIBLE_DEVICES=0  # GPU device IDs
MIXED_PRECISION=bf16   # or 'fp16' for V100/A10
USE_GRADIENT_CHECKPOINTING=true
USE_FLASH_ATTENTION=true
SEED=42

# =========================
# PATHS
# =========================
DATA_DIR=./data/processed
CACHE_DIR=./hf_cache
OUTPUT_DIR=./outputs
LOG_DIR=./logs
CHECKPOINT_DIR=./checkpoints

# =========================
# DEVELOPMENT
# =========================
DEBUG=false
VERBOSE=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
RANDOM_SEED=42

# =========================
# OPTIONAL: Local Development
# =========================
# For testing on CPU/single GPU locally
USE_LOCAL_TRAINING=false
NUM_WORKERS=4
PIN_MEMORY=true
