# ============================================================================
# ENVIRONMENT VARIABLES - Copy to .env and fill in your values
# ============================================================================
# Only variables actually read by Python code or shell scripts belong here.
# Training hyperparameters (batch size, LR, LoRA rank, etc.) are passed as
# CLI arguments by the scripts — override them there, not here.

# =========================
# HUGGING FACE
# Used for uploading trained model adapters and synthetic dataset to HF Hub.
# =========================
HF_TOKEN=your_hugging_face_token_here
HF_USER=your_hf_username_here
HF_REPO_ID=qwen3-8b-tool-use-lora
# HF_DATASET_REPO_ID=your_hf_username_here/qwen3-8b-synthetic-tool-use  # for dataset upload

# =========================
# WEIGHTS & BIASES
# =========================
WANDB_API_KEY=your_wandb_api_key_here
WANDB_ENTITY=your_wandb_entity_here
WANDB_PROJECT=qwen3-8b-tool-use
WANDB_MODE=online

# =========================
# TINKER API
# =========================
TINKER_API_KEY=your_tinker_api_key_here
