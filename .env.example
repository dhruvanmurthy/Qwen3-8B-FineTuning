# ============================================================================
# ENVIRONMENT VARIABLES - Copy to .env and fill in your values
# ============================================================================

# =========================
# HUGGING FACE
# =========================
HF_TOKEN=your_hugging_face_token_here
HF_USER=dhruvanmurthy
HF_REPO_ID=qwen3-8b-tool-use-lora

# =========================
# WEIGHTS & BIASES
# =========================
WANDB_API_KEY=your_wandb_api_key_here
WANDB_ENTITY=dhruvanmurthy
WANDB_PROJECT=qwen3-8b-tool-use
WANDB_MODE=online  # or 'offline' for local development

# =========================
# TINKER API
# =========================
TINKER_API_KEY=your_tinker_api_key_here

# =========================
# TRAINING CONFIGURATION
# =========================
TRAINING_BATCH_SIZE=16
EVALUATION_BATCH_SIZE=32
LEARNING_RATE=2e-4
NUM_EPOCHS=3
MAX_SEQ_LENGTH=2048
WARMUP_RATIO=0.1
WEIGHT_DECAY=0.01

# Dataset
DATASET_SIZE=20000  # raw samples per synthetic generation (actual train ~3,043 after balance)
TRAIN_SPLIT_RATIO=0.8
VAL_SPLIT_RATIO=0.1
TEST_SPLIT_RATIO=0.1

# QLoRA
LORA_R=64
LORA_ALPHA=16
LORA_DROPOUT=0.05
TARGET_MODULES="q_proj,v_proj,k_proj,o_proj,gate_proj,up_proj,down_proj"

# =========================
# COMPUTE & HARDWARE
# =========================
CUDA_VISIBLE_DEVICES=0,1,2,3  # GPU device IDs (comma-separated for multi-GPU)
MIXED_PRECISION=bf16   # or 'fp16' for V100/A10
USE_GRADIENT_CHECKPOINTING=true
USE_FLASH_ATTENTION=true
SEED=42

# =========================
# PATHS
# =========================
DATA_DIR=./data/processed
CACHE_DIR=./hf_cache
OUTPUT_DIR=./outputs
LOG_DIR=./logs
CHECKPOINT_DIR=./checkpoints

# =========================
# DEVELOPMENT
# =========================
DEBUG=false
VERBOSE=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
RANDOM_SEED=42

# =========================
# OPTIONAL: Local Development
# =========================
# For testing on CPU/single GPU locally
USE_LOCAL_TRAINING=false
NUM_WORKERS=4
PIN_MEMORY=true
